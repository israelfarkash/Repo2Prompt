# =============================================================
# AI Project Reverse Engineer — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# ─── Database ────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_reverse_engineer
DB_PORT=5432

# Full connection string (used by backend internally)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_reverse_engineer

# ─── AI Configuration ───────────────────────────────────────
# Your Google Gemini API key (required)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# AI provider: gemini (default), openai, claude (future)
AI_PROVIDER=gemini

# Gemini model to use
AI_MODEL=gemini-2.5-flash

# ─── GitHub ──────────────────────────────────────────────────
# Optional: GitHub personal access token for private repositories
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── Security & Limits ──────────────────────────────────────
# Maximum repository size in MB (default: 100)
MAX_REPO_SIZE_MB=100

# Analysis timeout in seconds (default: 600 = 10 minutes)
ANALYSIS_TIMEOUT_SECONDS=600

# ─── Application Ports ──────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ─── Internal ────────────────────────────────────────────────
# Directory for cloning repositories (inside container)
CLONE_DIR=/tmp/repos
